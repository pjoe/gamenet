{
  "name": "@gamenet/core",
  "version": "0.0.5",
  "type": "module",
  "repository": {
    "url": "https://github.com/pjoe/gamenet"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react/GameContext.d.ts",
      "import": "./dist/react/GameContext.js"
    },
    "./worker-setup": {
      "types": "./dist/routing/host_server_worker_setup.d.ts",
      "import": "./dist/routing/host_server_worker_setup.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.build.json",
    "dev": "vite build --watch"
  },
  "dependencies": {
    "@msgpack/msgpack": "^3.1.3",
    "cbor-x": "^1.6.4",
    "mitt": "^3.0.1",
    "mqtt": "^5.15.1",
    "nanoid": "^5.1.7"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.2",
    "vite": "^8.0.2",
    "ws": "^8.20.0"
  }
}
