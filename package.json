{
  "name": "gamenet-monorepo",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @gamenet/example-app dev",
    "dev:bjs": "pnpm --filter @gamenet/example-app-bjs dev",
    "build": "pnpm --filter @gamenet/core build && pnpm --filter @gamenet/example-ui build && pnpm --filter @gamenet/example-app build",
    "build:bjs": "pnpm --filter @gamenet/example-app-bjs build",
    "build:lib": "pnpm --filter @gamenet/core build && pnpm --filter @gamenet/example-ui build",
    "preview": "pnpm --filter @gamenet/example-app preview",
    "preview:bjs": "pnpm --filter @gamenet/example-app-bjs preview",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules jest",
    "test:watch": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "cross-env NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "local-server": "tsx packages/gamenet/src/signal_server_local_server.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"{packages,apps}/**/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"{packages,apps}/**/src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@jest/globals": "^30.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-react-hooks": "7.1.0-canary-ab18f33d-20260220",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "jest": "^30.3.0",
    "node-datachannel": "^0.32.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.57.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-datachannel",
      "unrs-resolver"
    ],
    "overrides": {
      "minimatch": ">=10.2.3",
      "flatted@<3.4.0": ">=3.4.0",
      "flatted@<=3.4.1": ">=3.4.2",
      "test-exclude": ">=7.0.0"
    },
    "peerDependencyRules": {
      "allowAny": [
        "typescript"
      ]
    }
  }
}
