{
  "name": "gamenet-monorepo",
  "private": true,
  "version": "0.0.1",
  "packageManager": "pnpm@10.0.0",
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @gamenet/example-app dev",
    "build": "pnpm --filter @gamenet/core build && pnpm --filter @gamenet/example-ui build && pnpm --filter @gamenet/example-app build",
    "build:lib": "pnpm --filter @gamenet/core build && pnpm --filter @gamenet/example-ui build",
    "preview": "pnpm --filter @gamenet/example-app preview",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --forceExit",
    "test:watch": "NODE_OPTIONS=--experimental-vm-modules jest --watch",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage --forceExit",
    "local-server": "tsx packages/gamenet/src/signal_server_local_server.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"{packages,apps}/**/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"{packages,apps}/**/src/**/*.{ts,tsx,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "eslint": "^10.0.1",
    "eslint-plugin-react-hooks": "7.1.0-canary-ab18f33d-20260220",
    "eslint-plugin-react-refresh": "^0.5.0",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "node-datachannel": "^0.32.1",
    "prettier": "^3.8.1",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.56.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "node-datachannel",
      "unrs-resolver"
    ]
  },
  "overrides": {
    "minimatch": "^10.2.1"
  }
}
